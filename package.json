{
  "dependencies": {
    "tailwindcss": "^4.1.16"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npx @tailwindcss/cli -i ./src/inputcustomermain.css -o ./public/css/output.css",
    "dev-login": "npx @tailwindcss/cli -i ./src/inputlogin.css -o ./public/css/login.css --watch",
    "dev-home": "npx @tailwindcss/cli -i ./src/inputhome.css -o ./public/css/home.css --watch",
    "dev-app": "npx @tailwindcss/cli -i ./src/inputlayout.css -o ./public/css/app.css --watch",
    "dev-seller": "npx @tailwindcss/cli -i ./src/inputsellerportal.css -o ./public/css/sellerportal.css --watch",
    "dev-category": "npx @tailwindcss/cli -i ./src/categories-input.css -o ./public/css/categories.css --watch",
    "dev-product": "npx @tailwindcss/cli -i ./src/product-details-input.css -o ./public/css/product-details.css --watch",
    "dev-s-registration": "npx @tailwindcss/cli -i ./src/seller-registration.css -o ./public/css/seller-registration.css --watch",
    "dev-checkout": "npx @tailwindcss/cli -i ./src/input-checkout.css -o ./public/css/checkout.css --watch",
    "dev-all": "npm-run-all --parallel build dev-login dev-home dev-app dev-seller dev-category dev-product dev-s-registration dev-checkout"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}